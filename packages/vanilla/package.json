{
  "name": "@tiptap-block-kit/vanilla",
  "version": "0.0.2",
  "description": "Custom component extension kit for Tiptap (Vanilla JS)",
  "keywords": [
    "tiptap",
    "editor",
    "rich-text",
    "vanilla",
    "javascript",
    "extension",
    "custom-component"
  ],
  "author": "suehwanBoo",
  "license": "MIT",
  "homepage": "https://github.com/suehwanBoo/tiptap-block-kit#readme",
  "bugs": {
    "url": "https://github.com/suehwanBoo/tiptap-block-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/suehwanBoo/tiptap-block-kit"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@tiptap/core": "^2 || ^3"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
