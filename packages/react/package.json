{
  "name": "@tiptap-block-kit/react",
  "version": "0.0.1",
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --clean",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tiptap-block-kit/core": "workspace:*"
  },
  "peerDependencies": {
    "@tiptap/core": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
