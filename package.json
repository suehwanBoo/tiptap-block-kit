    "dev:react": "pnpm --filter react run dev"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "overrides": {
      "@tiptap/core": "2.27.2",
      "@tiptap/pm": "2.27.2",
      "@tiptap/react": "2.27.2",
      "@tiptap/starter-kit": "2.27.2"
    }
  }
}
